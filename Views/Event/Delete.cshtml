@model ArtClub.Models.ViewModels.EventDetailsViewModel

@{
    ViewData["Title"] = "Delete event";
}

<h1>Delete event</h1>

<div class="alert alert-danger">
    Are you sure you want to delete this event?
</div>

<div class="card mb-3">
    <div class="card-body">
        <h2 class="h5">@Model.Title</h2>

        <p class="mb-1"><strong>Organizer:</strong> @Model.OrganizerName</p>
        <p class="mb-1"><strong>Resource:</strong> @Model.ResourceName</p>
        <p class="mb-0"><strong>Date:</strong> @Model.Date.ToString("dd MMM yyyy")</p>
    </div>
</div>

<form asp-action="DeleteConfirmed" method="post">
    @Html.AntiForgeryToken()

    <input type="hidden" name="title" value="@Model.Title" />

    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>