@model ArtClub.Models.ViewModels.EventDetailsViewModel

@{
    ViewData["Title"] = "Event Details";
}

<div class="card">
    <div class="card-body">
        <h1 class="h3">@Model.Title</h1>

        <p><strong>Organizer:</strong> @Model.OrganizerName</p>
        <p><strong>Resource:</strong> @Model.ResourceName</p>
        <p><strong>Date:</strong> @Model.Date.ToString("dd MMM yyyy")</p>
        <p><strong>Attending members:</strong> @Model.AttendingCount</p>

        <h2 class="h5 mt-4">Displayed art pieces</h2>

        @if (Model.ArtPieceNames != null && Model.ArtPieceNames.Any())
        {
            <ul>
                @foreach (var item in Model.ArtPieceNames)
                {
                    <li>@item</li>
                }
            </ul>
        }
        else
        {
            <p class="text-muted mb-0">No related art pieces are listed.</p>
        }

        <div class="mt-4">
            <a asp-action="Edit" asp-route-title="@Model.Title" class="btn btn-primary">Edit</a>
            <a asp-action="Delete" asp-route-title="@Model.Title" class="btn btn-danger">Delete</a>
            <a asp-action="Index" class="btn btn-secondary">Back</a>
        </div>
    </div>
</div>