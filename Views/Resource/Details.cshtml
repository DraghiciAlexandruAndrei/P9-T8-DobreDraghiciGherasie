@model ArtClub.Models.Entities.Resource

@{
    ViewData["Title"] = "Resource details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1>Resource details</h1>
        <p class="text-muted mb-0">Review resource information and reservation history.</p>
    </div>

    <a asp-action="Index" class="btn btn-secondary">Back to resources</a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <h2 class="h4">@Model.Name</h2>

        <div class="row">
            <div class="col-md-6">
                <p class="mb-1"><strong>Description / Type:</strong> @Model.Description</p>
                <p class="mb-1"><strong>Capacity:</strong> @Model.Capacity</p>
                <p class="mb-1"><strong>Base price:</strong> @Model.BasePrice</p>
            </div>

            <div class="col-md-6">
                <p class="mb-1"><strong>Location:</strong> Club venue</p>
                <p class="mb-1">
                    <strong>Status:</strong>
                    @{
                        var isReservedNow = Model.Reservations != null && Model.Reservations.Any(res =>
                            res.StartTime.AddDays(-1) <= DateTime.Now &&
                            res.EndTime.AddDays(1) >= DateTime.Now);
                    }
                    @(isReservedNow ? "Reserved" : "Available")
                </p>
            </div>
        </div>

        <div class="mt-3">
            <a asp-action="Edit" asp-route-name="@Model.Name" class="btn btn-primary">Edit</a>
            <a asp-action="Delete" asp-route-name="@Model.Name" class="btn btn-danger">Delete</a>
        </div>
    </div>
</div>

<h3>Reservations</h3>

@if (Model.Reservations != null && Model.Reservations.Any())
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Start time</th>
                <th>End time</th>
                <th>Buffer starts</th>
                <th>Buffer ends</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var res in Model.Reservations.OrderBy(r => r.StartTime))
            {
                <tr>
                    <td>@res.StartTime.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@res.EndTime.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@res.StartTime.AddDays(-1).ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@res.EndTime.AddDays(1).ToString("dd.MM.yyyy HH:mm")</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-secondary">
        No reservations for this resource.
    </div>
}