@model IEnumerable<ArtClub.Models.Entities.User>

@{
    ViewData["Title"] = "Manage Users";
}

<h1>Manage Users</h1>

<form asp-action="Users" method="get" class="row g-2 my-3">
    <div class="col-md-4">
        <input type="text" name="search" value="@ViewBag.Search"
               class="form-control" placeholder="Search by name or email" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">Search</button>
        <a asp-action="Users" class="btn btn-outline-secondary">Clear</a>
    </div>
</form>

@if (TempData["StatusMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["StatusMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<table class="table table-striped table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Username</th>
            <th>Email</th>
            <th>Role</th>
            <th>Active</th>
            <th>Banned</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var user in Model)
    {
        <tr>
            <td>@user.Id</td>
            <td>@user.UserName</td>
            <td>@user.Email</td>
            <td>
                <span class="badge @(user.Role.ToString() == "Admin" ? "bg-danger" : user.Role.ToString() == "Member" ? "bg-primary" : "bg-secondary")">
                    @user.Role
                </span>
            </td>
            <td>
                @if (user.IsActive)
                {
                    <span class="badge bg-success">Active</span>
                }
                else
                {
                    <span class="badge bg-warning text-dark">Inactive</span>
                }
            </td>
            <td>
                @if (user.IsBanned)
                {
                    <span class="badge bg-danger">Banned</span>
                }
                else
                {
                    <span class="badge bg-light text-dark">No</span>
                }
            </td>
            <td class="d-flex gap-1 flex-wrap">
                <a asp-action="EditRole" asp-route-id="@user.Id"
                   class="btn btn-sm btn-outline-primary">Change Role</a>

                @if (!user.IsBanned)
                {
                    <form asp-action="BanUser" method="post" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@user.Id" />
                        <button type="submit" class="btn btn-sm btn-danger"
                                onclick="return confirm('Ban this user?')">Ban</button>
                    </form>
                }
                else
                {
                    <form asp-action="UnbanUser" method="post" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@user.Id" />
                        <button type="submit" class="btn btn-sm btn-success">Unban</button>
                    </form>
                }
            </td>
        </tr>
    }
    </tbody>
</table>

<a asp-action="Index" class="btn btn-secondary mt-2">← Back to Dashboard</a>