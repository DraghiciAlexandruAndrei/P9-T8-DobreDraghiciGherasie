@model IEnumerable<ArtClub.Models.Entities.Resource>

@{
    ViewData["Title"] = "Manage Resources";
}

<div class="d-flex justify-content-between align-items-center my-3">
    <h1>Manage Resources</h1>
    <a asp-action="CreateResource" class="btn btn-success">+ Add Resource</a>
</div>

@if (TempData["StatusMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["StatusMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<table class="table table-striped table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Description</th>
            <th>Capacity</th>
            <th>Base Price (lei/day)</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var r in Model)
    {
        <tr>
            <td>@r.Id</td>
            <td>@r.Name</td>
            <td>@r.Description</td>
            <td>@r.Capacity</td>
            <td>@r.BasePrice.ToString("N2")</td>
            <td class="d-flex gap-1">
                <a asp-action="EditResource" asp-route-id="@r.Id"
                   class="btn btn-sm btn-outline-primary">Edit</a>
                <form asp-action="DeleteResource" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@r.Id" />
                    <button type="submit" class="btn btn-sm btn-danger"
                            onclick="return confirm('Delete this resource?')">Delete</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>

<a asp-action="Index" class="btn btn-secondary mt-2">← Back to Dashboard</a>