@model ArtClub.Models.ViewModels.ResourceCreateViewModel

@{
    ViewData["Title"] = "Edit resource";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1>Edit resource</h1>
        <p class="text-muted mb-0">Update the resource information used for event planning and reservations.</p>
    </div>

    <a asp-action="Index" class="btn btn-secondary">Back to resources</a>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="Edit" method="post" class="row g-3">
            @Html.AntiForgeryToken()

            <input type="hidden" name="originalName" value="@Model.Name" />

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="col-12">
                <label asp-for="Name" class="form-label">Resource name</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="ResourceTypeId" class="form-label">Resource category</label>
                <select asp-for="ResourceTypeId" asp-items="Model.ResourceTypes" class="form-select">
                    <option value="">-- Select category --</option>
                </select>
                <span asp-validation-for="ResourceTypeId" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Type" class="form-label">Specific type/label</label>
                <input asp-for="Type" class="form-control" />
                <span asp-validation-for="Type" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Capacity" class="form-label">Capacity (venues only)</label>
                <input asp-for="Capacity" type="number" min="1" class="form-control" />
                <span asp-validation-for="Capacity" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="QuantityAvailable" class="form-label">Quantity (equipment/art pieces)</label>
                <input asp-for="QuantityAvailable" type="number" min="1" class="form-control" />
                <span asp-validation-for="QuantityAvailable" class="text-danger"></span>
            </div>

            <div class="col-12">
                <label asp-for="Location" class="form-label">Location (for halls)</label>
                <input asp-for="Location" class="form-control" />
                <span asp-validation-for="Location" class="text-danger"></span>
            </div>

            <div class="col-12">
                <label asp-for="ImageUrl" class="form-label">Image URL (optional)</label>
                <input asp-for="ImageUrl" class="form-control" />
                <span asp-validation-for="ImageUrl" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="BasePrice" class="form-label">Base price</label>
                <input asp-for="BasePrice" type="number" min="0" step="0.01" class="form-control" />
                <span asp-validation-for="BasePrice" class="text-danger"></span>
            </div>

            <div class="col-12 form-check">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label">Active (bookable)</label>
            </div>

            <div class="col-12 form-check">
                <input asp-for="IsAffiliatedVenue" class="form-check-input" />
                <label asp-for="IsAffiliatedVenue" class="form-check-label">External hall (affiliated)</label>
            </div>

            <div class="col-12">
                <button type="submit" class="btn btn-primary">Save changes</button>
                <a asp-action="Details" asp-route-name="@Model.Name" class="btn btn-outline-secondary">View details</a>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function toggleResourceFields() {
            const typeSelect = document.getElementById('ResourceTypeId');
            if (!typeSelect) return;

            const selected = parseInt(typeSelect.value || '-1', 10);
            const isHall = selected === 0;

            const capacityField = document.querySelector('[name="Capacity"]')?.closest('.col-md-6');
            const quantityField = document.querySelector('[name="QuantityAvailable"]')?.closest('.col-md-6');
            const locationField = document.querySelector('[name="Location"]')?.closest('.col-12');
            const affiliatedField = document.querySelector('[name="IsAffiliatedVenue"]')?.closest('.col-12');

            if (capacityField) capacityField.style.display = isHall ? '' : 'none';
            if (locationField) locationField.style.display = isHall ? '' : 'none';
            if (affiliatedField) affiliatedField.style.display = isHall ? '' : 'none';
            if (quantityField) quantityField.style.display = isHall ? 'none' : '';
        }

        document.getElementById('ResourceTypeId')?.addEventListener('change', toggleResourceFields);
        window.addEventListener('load', toggleResourceFields);
    </script>
}