@model IEnumerable<ArtClub.Models.ViewModels.EventSummaryViewModel>
@{
    ViewData["Title"] = "Events";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1>Events</h1>
        <p class="text-muted mb-0">Create, review, and manage club events and invitations.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">Create event</a>
</div>

@if (Model?.Any() == true)
{
    <div class="row g-3">
        @foreach (var item in Model)
        {
            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h2 class="h5">@item.Title</h2>
                        <p class="mb-1"><strong>Organizer:</strong> @item.OrganizerName</p>
                        <p class="mb-1"><strong>Resource:</strong> @item.ResourceName</p>
                        <p class="mb-1"><strong>Date:</strong> @item.StartDate.ToString("dd MMM yyyy")</p>
                        <p class="mb-3"><strong>Status:</strong> @item.Status</p>
                        <a asp-action="Details" asp-route-id="1" class="btn btn-sm btn-outline-primary">Open details</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="alert alert-secondary">No events are available yet.</div>
}
