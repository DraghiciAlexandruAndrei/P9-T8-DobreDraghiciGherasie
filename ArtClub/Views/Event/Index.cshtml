@model IEnumerable<ArtClub.Models.ViewModels.EventSummaryViewModel>
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = "Events";
    // Verificăm dacă utilizatorul este autentificat și ce status are
    var userId = HttpContextAccessor.HttpContext.Session.GetInt32("UserId");
    var isActive = HttpContextAccessor.HttpContext.Session.GetString("IsMembershipActive") == "True";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1>Events</h1>
        <p class="text-muted mb-0">Gestionați evenimentele clubului și invitațiile artiștilor.</p>
    </div>

    @if (userId != null)
    {
        <div class="text-end">
            <a asp-action="Create" class="btn btn-primary shadow-sm">
                <i class="bi bi-plus-circle"></i> Create event
            </a>
            @if (!isActive)
            {
                <div class="small text-warning mt-1">
                    <i class="bi bi-exclamation-triangle"></i> Limită: 1 eveniment gratuit
                </div>
            }
        </div>
    }
</div>

@if (Model?.Any() == true)
{
    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-4">
                <div class="card h-100 shadow-sm border-0 transition-hover">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h2 class="h5 card-title mb-0">@item.Title</h2>
                            <span class="badge @(item.Status == "Scheduled" ? "bg-success" : "bg-secondary")">
                                @item.Status
                            </span>
                        </div>

                        <div class="card-text small">
                            <p class="mb-1 text-truncate"><strong><i class="bi bi-person"></i> Organizer:</strong> @item.OrganizerName</p>
                            <p class="mb-1"><strong><i class="bi bi-geo-alt"></i> Resource:</strong> @item.ResourceName</p>
                            <p class="mb-1"><strong><i class="bi bi-calendar3"></i> Date:</strong> @item.StartDate.ToString("dd MMM yyyy")</p>
                            <p class="mb-3"><strong><i class="bi bi-people"></i> Invitations:</strong> @item.InviteCount</p>
                        </div>

                        @* REPARAȚIA AICI: Folosim ID-ul real al evenimentului *@
                        <a asp-action="Details" asp-route-id="@item.Title" class="btn btn-sm btn-outline-primary w-100 mt-2">
                            View details
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="text-center py-5">
        <i class="bi bi-calendar-x display-1 text-muted"></i>
        <p class="mt-3 fs-5 text-muted">No events are available yet.</p>
        <a asp-action="Create" class="btn btn-primary mt-2">Be the first to create one!</a>
    </div>
}

<style>
    .transition-hover:hover {
        transform: translateY(-5px);
        transition: transform 0.3s ease;
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
</style>