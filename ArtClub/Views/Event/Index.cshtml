@model IEnumerable<ArtClub.Models.ViewModels.EventSummaryViewModel>

@{
    ViewData["Title"] = "Events";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1>Events</h1>
        <p class="text-muted mb-0">Create, review, and manage club events and invitations.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">Create event</a>
</div>

@if (TempData["StatusMessage"] != null)
{
    <div class="alert alert-success">@TempData["StatusMessage"]</div>
}

@if (Model?.Any() == true)
{
    <div class="row g-3">
        @foreach (var item in Model)
        {
            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h2 class="h5">@item.Title</h2>
                        <p class="mb-1"><strong>Organizer:</strong> @item.OrganizerName</p>
                        <p class="mb-1"><strong>Resource:</strong> @item.ResourceName</p>
                        <p class="mb-1"><strong>Date:</strong> @item.StartDate.ToString("dd MMM yyyy")</p>
                        <p class="mb-1"><strong>Invites:</strong> @item.InviteCount</p>
                        <p class="mb-3"><strong>Status:</strong> @item.Status</p>

                        <div class="d-flex gap-2 flex-wrap">
                            <a asp-action="Details"
                               asp-route-title="@item.Title"
                               class="btn btn-sm btn-outline-primary">
                                Details
                            </a>

                            <a asp-action="Edit"
                               asp-route-title="@item.Title"
                               class="btn btn-sm btn-outline-warning">
                                Edit
                            </a>

                            <a asp-action="Delete"
                               asp-route-title="@item.Title"
                               class="btn btn-sm btn-outline-danger">
                                Delete
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="alert alert-secondary">No events are available yet.</div>
}
