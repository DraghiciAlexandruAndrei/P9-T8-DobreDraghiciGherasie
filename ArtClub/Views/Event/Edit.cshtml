@model ArtClub.Models.ViewModels.EventCreateViewModel
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = "Editează eveniment";
    var originalTitle = ViewBag.OriginalTitle as string;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h1>Editează Eveniment: @originalTitle</h1>
        <a asp-action="Details" asp-route-title="@originalTitle" class="btn btn-outline-secondary">
            <i class="bi bi-x-circle"></i> Anulează
        </a>
    </div>
    <hr />

    <div class="row">
        <div class="col-md-8">
            <!-- Trimitem originalTitle ca parametru în rută pentru a ști ce edităm -->
            <form asp-action="Edit" asp-route-originalTitle="@originalTitle" method="post" class="row g-3 shadow-sm p-4 bg-light rounded">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="col-12">
                    <label asp-for="Title" class="form-label font-weight-bold">Titlu Nou Eveniment</label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Description" class="form-label font-weight-bold">Descriere Detaliată</label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="StartDate" class="form-label font-weight-bold">Data Început</label>
                    <input asp-for="StartDate" type="datetime-local" class="form-control" id="startDate" />
                    <span asp-validation-for="StartDate" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="EndDate" class="form-label font-weight-bold">Data Sfârșit</label>
                    <input asp-for="EndDate" type="datetime-local" class="form-control" id="endDate" />
                    <span asp-validation-for="EndDate" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="ResourceName" class="form-label font-weight-bold text-primary">Schimbă Sala (300 lei/zi)</label>
                    <select asp-for="ResourceName" asp-items="Model.AvailableResources" class="form-select border-primary">
                        <option value="">-- Selectează locația --</option>
                    </select>
                    <span asp-validation-for="ResourceName" class="text-danger"></span>
                </div>

                @* REQ-5: Multi-select pentru piese de artă *@
                <div class="col-md-6">
                    <label asp-for="SelectedArtPieceIds" class="form-label font-weight-bold text-primary">Piese de Artă (200 lei/buc/zi)</label>
                    <select asp-for="SelectedArtPieceIds"
                            class="form-select border-primary"
                            multiple
                            size="4"
                            id="artPieces"
                            asp-items="@(ViewBag.ArtPiecesList as IEnumerable<SelectListItem>)">
                    </select>
                    <small class="text-muted">Ține apăsat <strong>Ctrl</strong> pentru a adăuga/elimina piese.</small>
                </div>

                <div class="col-12 mt-4">
                    <div class="alert alert-info d-flex justify-content-between align-items-center">
                        <div>
                            <strong>Recalculare Cost Estimativ:</strong>
                            <span id="estimatedCost" class="h5 mb-0 ms-2">0</span> lei
                        </div>
                        <button type="submit" class="btn btn-warning btn-lg px-5">
                            <i class="bi bi-save"></i> Salvează Modificările
                        </button>
                    </div>
                </div>
            </form>
        </div>

        <div class="col-md-4">
            <div class="card border-warning shadow-sm">
                <div class="card-header bg-warning text-dark font-weight-bold">
                    <i class="bi bi-info-circle"></i> Notă la Editare
                </div>
                <div class="card-body">
                    <p class="small text-muted">
                        Modificarea datei sau a numărului de piese de artă va <strong>actualiza automat bugetul</strong> evenimentului.
                    </p>
                    <ul class="list-unstyled mb-0">
                        <li>🏢 Locație: 300 lei / zi</li>
                        <li>🎨 Artă: 200 lei / piesă / zi</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function calculatePreview() {
            const startVal = document.getElementById('startDate').value;
            const endVal = document.getElementById('endDate').value;
            const artSelect = document.getElementById('artPieces');

            if (startVal && endVal) {
                const start = new Date(startVal);
                const end = new Date(endVal);

                if (end > start) {
                    const diffTime = Math.abs(end - start);
                    // Calculăm numărul de zile (minim 1 zi)
                    const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24)) || 1;

                    const artCount = Array.from(artSelect.selectedOptions).length;

                    const total = (diffDays * 300) + (diffDays * artCount * 200);
                    document.getElementById('estimatedCost').innerText = total;
                } else {
                    document.getElementById('estimatedCost').innerText = "0 (Data invalidă)";
                }
            }
        }

        // Atașăm evenimentele de schimbare pentru recalculare live
        document.querySelectorAll('#startDate, #endDate, #artPieces').forEach(el => {
            el.addEventListener('change', calculatePreview);
        });

        // Calculăm inițial la încărcarea paginii
        window.onload = calculatePreview;
    </script>
}