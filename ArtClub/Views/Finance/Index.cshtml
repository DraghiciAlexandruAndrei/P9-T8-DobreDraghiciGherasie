@model ArtClub.Models.ViewModels.FinanceDashboardViewModel
@{
    ViewData["Title"] = "Finance Dashboard";
}

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card h-100"><div class="card-body"><h2 class="h5">Income</h2><p class="display-6">@Model?.TotalIncome lei</p></div></div>
    </div>
    <div class="col-md-4">
        <div class="card h-100"><div class="card-body"><h2 class="h5">Expenses</h2><p class="display-6">@Model?.TotalExpenses lei</p></div></div>
    </div>
    <div class="col-md-4">
        <div class="card h-100"><div class="card-body"><h2 class="h5">Balance</h2><p class="display-6">@Model?.NetBalance lei</p><p class="mb-0">Club status: @(Model?.HasTheClubEnoughMoney == true ? "Healthy" : "Restricted")</p></div></div>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <h2 class="h5">Recent transactions</h2>
        @if (Model?.RecentTransactions?.Any() == true)
        {
            <ul class="mb-0">
                @foreach (var item in Model.RecentTransactions)
                {
                    <li>@item</li>
                }
            </ul>
        }
        else
        {
            <p class="text-muted mb-0">No transactions available.</p>
        }
    </div>
</div>
