@model ArtClub.Models.Entities.Payment

@{
    ViewData["Title"] = "Delete payment";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1>Delete payment</h1>
        <p class="text-muted mb-0">Confirm removal of this finance record.</p>
    </div>

    <a asp-action="Payments" class="btn btn-secondary">Back to payments</a>
</div>

<div class="alert alert-danger">
    <strong>Warning:</strong> This action will delete the selected payment record.
</div>

<div class="card mb-3">
    <div class="card-body">
        <p class="mb-1"><strong>Date:</strong> @Model.Date.ToString("dd.MM.yyyy")</p>
        <p class="mb-1"><strong>Type:</strong> @(Model.IsIncome ? "Income" : "Expense")</p>
        <p class="mb-0"><strong>Amount:</strong> @Model.Amount lei</p>
    </div>
</div>

<form asp-action="DeleteConfirmed" method="post">
    @Html.AntiForgeryToken()

    <input type="hidden" name="id" value="@Model.Id" />

    <button type="submit" class="btn btn-danger">Delete payment</button>
    <a asp-action="Payments" class="btn btn-secondary">Cancel</a>
</form>