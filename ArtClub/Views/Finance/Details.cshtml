@model ArtClub.Models.Entities.Payment

@{
    ViewData["Title"] = "Payment details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1>Payment details</h1>
        <p class="text-muted mb-0">Review the selected income or expense record.</p>
    </div>

    <a asp-action="Payments" class="btn btn-secondary">Back to payments</a>
</div>

<div class="card mb-3">
    <div class="card-body">
        <h2 class="h5">
            @(Model.IsIncome ? "Income record" : "Expense record")
        </h2>

        <p class="mb-1"><strong>Date:</strong> @Model.Date.ToString("dd.MM.yyyy")</p>
        <p class="mb-1"><strong>Type:</strong> @(Model.IsIncome ? "Income" : "Expense")</p>
        <p class="mb-0"><strong>Amount:</strong> @Model.Amount lei</p>
    </div>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Delete</a>
    <a asp-action="Payments" class="btn btn-secondary">Back</a>
</div>