@model IEnumerable<ArtClub.Models.Entities.Payment>

@{
    ViewData["Title"] = "Payments";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1>Payments</h1>
        <p class="text-muted mb-0">Manage income and expense records for the club.</p>
    </div>

    <div>
        <a asp-action="Dashboard" class="btn btn-outline-secondary">Dashboard</a>
        <a asp-action="Create" class="btn btn-primary">Add payment</a>
    </div>
</div>

@if (TempData["StatusMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["StatusMessage"]
    </div>
}

@if (Model != null && Model.Any())
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Date</th>
                <th>Type</th>
                <th>Amount</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var payment in Model)
            {
                <tr>
                    <td>@payment.Date.ToString("dd.MM.yyyy")</td>

                    <td>
                        @if (payment.IsIncome)
                        {
                            <span class="badge bg-success">Income</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Expense</span>
                        }
                    </td>

                    <td>@payment.Amount lei</td>

                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@payment.Id" class="btn btn-sm btn-outline-primary">
                            Details
                        </a>

                        <a asp-action="Edit" asp-route-id="@payment.Id" class="btn btn-sm btn-outline-secondary">
                            Edit
                        </a>

                        <a asp-action="Delete" asp-route-id="@payment.Id" class="btn btn-sm btn-outline-danger">
                            Delete
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-secondary">
        No payment records are available yet.
    </div>
}