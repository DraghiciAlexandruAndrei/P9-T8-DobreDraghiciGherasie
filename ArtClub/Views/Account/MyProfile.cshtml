@model ArtClub.Models.ViewModels.MyProfileViewModel

@{
    ViewData["Title"] = "Profilul Meu";
}

<div class="container mt-5">
    <!-- Mesaje de succes/eroare -->
    @if (TempData["StatusMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["StatusMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <!-- COLOANA STÂNGA: Informații Utilizator & Membership -->
        <div class="col-lg-4 mb-4">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-body text-center p-4">
                    <div class="mb-3">
                        <i class="bi bi-person-circle text-primary" style="font-size: 5rem;"></i>
                    </div>
                    <h4 class="fw-bold mb-1">@Model.UserName</h4>
                    <p class="text-muted small mb-3">@Model.Email</p>
                    <div class="badge bg-light text-dark border px-3 py-2 mb-4">
                        Membru din: @Model.JoinedDate.ToString("dd MMM yyyy")
                    </div>

                    <hr class="my-4">

                    <div class="membership-card p-3 rounded-3 @(Model.IsMembershipActive ? "bg-light-success border-success" : "bg-light border")"
                         style="background-color: @(Model.IsMembershipActive ? "#f0fff4" : "#f8f9fa");">
                        <h6 class="fw-bold mb-2">Status Abonament</h6>

                        @if (Model.IsMembershipActive)
                        {
                            <div class="text-success fw-bold">
                                <i class="bi bi-patch-check-fill me-1"></i> MEMBRU PREMIUM
                            </div>
                            <p class="small text-muted mt-2 mb-0">Beneficiezi de taxe administrative 0 și prioritare la rezervări.</p>
                        }
                        else
                        {
                            <div class="text-secondary fw-bold mb-3">UTILIZATOR STANDARD</div>
                            <p class="small text-muted mb-3 text-start">
                                <i class="bi bi-info-circle me-1"></i> Membrii nu plătesc taxa de administrare de <strong>400 RON</strong> pentru evenimente.
                            </p>
                            <form asp-action="BecomeMember" asp-controller="Account" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-warning w-100 fw-bold shadow-sm">
                                    <i class="bi bi-credit-card-2-front me-2"></i> DEVINO MEMBRU
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- COLOANA DREAPTĂ: Evenimente și Invitații -->
        <div class="col-lg-8">

            <!-- SECȚIUNE: Evenimentele Mele -->
            <div class="card shadow-sm border-0 mb-4 rounded-3">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center border-bottom">
                    <h5 class="mb-0 fw-bold text-dark">
                        <i class="bi bi-calendar-event me-2 text-primary"></i>Evenimentele Mele
                    </h5>
                    <a asp-controller="Event" asp-action="Create" class="btn btn-primary btn-sm rounded-pill px-3">
                        <i class="bi bi-plus-lg me-1"></i> Nou
                    </a>
                </div>
                <div class="card-body p-0">
                    @if (Model.MyOrganizedEvents != null && Model.MyOrganizedEvents.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-4">Titlu</th>
                                        <th>Locație</th>
                                        <th>Data</th>
                                        <th class="text-center">Status</th>
                                        <th class="text-end pe-4">Acțiuni</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var ev in Model.MyOrganizedEvents)
                                    {
                                        <tr>
                                            <td class="ps-4 fw-bold text-dark">@ev.Title</td>
                                            <td><span class="text-muted">@ev.ResourceName</span></td>
                                            <td class="small">@ev.StartDate.ToString("dd.MM.yyyy HH:mm")</td>
                                            <td class="text-center">
                                                <span class="badge rounded-pill @(ev.Status == "Viitor" ? "bg-info text-dark" : "bg-light text-muted border")">
                                                    @ev.Status
                                                </span>
                                            </td>
                                            <td class="text-end pe-4">
                                                <a asp-controller="Event" asp-action="Details" asp-route-title="@ev.Title"
                                                   class="btn btn-sm btn-outline-secondary rounded-circle">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="bi bi-calendar-x display-4 d-block mb-2"></i>
                            <p>Nu ai organizat încă niciun eveniment.</p>
                        </div>
                    }
                </div>
            </div>

            <!-- SECȚIUNE: Invitații Primite -->
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-white py-3 border-bottom">
                    <h5 class="mb-0 fw-bold text-dark">
                        <i class="bi bi-envelope-paper me-2 text-primary"></i>Invitații Primite
                    </h5>
                </div>
                <div class="card-body p-4">
                    @if (Model.PendingInvitations != null && Model.PendingInvitations.Any())
                    {
                        @foreach (var invite in Model.PendingInvitations)
                        {
                            <div class="p-3 mb-3 border rounded-3 bg-light shadow-sm">
                                <div class="row align-items-center">
                                    <div class="col-md-7">
                                        <h6 class="fw-bold text-primary mb-1">@invite.EventTitle</h6>
                                        <div class="small text-muted mb-2">
                                            <i class="bi bi-person me-1"></i> @invite.OrganizerName |
                                            <i class="bi bi-clock me-1"></i> @invite.EventDate.ToString("f")
                                        </div>
                                        <p class="small text-dark mb-0 fst-italic">"@invite.Description"</p>
                                    </div>
                                    <div class="col-md-5 text-md-end mt-3 mt-md-0">
                                        <div class="d-flex gap-2 justify-content-md-end">
                                            <form asp-controller="Account" asp-action="HandleInvitation" method="post">
                                                <input type="hidden" name="id" value="@invite.InvitationId" />
                                                <input type="hidden" name="accept" value="true" />
                                                <button type="submit" class="btn btn-success btn-sm px-3 shadow-sm">
                                                    <i class="bi bi-check-lg me-1"></i> Acceptă
                                                </button>
                                            </form>
                                            <form asp-controller="Account" asp-action="HandleInvitation" method="post">
                                                <input type="hidden" name="id" value="@invite.InvitationId" />
                                                <input type="hidden" name="accept" value="false" />
                                                <button type="submit" class="btn btn-outline-danger btn-sm px-3 shadow-sm">
                                                    <i class="bi bi-x-lg me-1"></i> Refuză
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-center text-muted my-3 small">Căsuța ta poștală este goală.</p>
                    }
                </div>
            </div>

        </div>
    </div>
</div>

<style>
    /* Stiluri suplimentare pentru finisare */
    .bg-light-success {
        background-color: #e6fffa;
        border: 1px solid #38a169;
    }

    .card {
        transition: transform 0.2s;
    }

    .table-hover tbody tr:hover {
        background-color: rgba(13, 110, 253, 0.03);
    }

    .btn-sm {
        font-size: 0.8rem;
    }
</style>