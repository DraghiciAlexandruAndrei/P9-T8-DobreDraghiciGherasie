@model IEnumerable<ArtClub.Models.ViewModels.ArtPieceListViewModel>
@{
    ViewData["Title"] = "Art Pieces";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1>Art Pieces</h1>
        <p class="text-muted mb-0">Browse the club collection and open detailed art piece pages.</p>
    </div>
    <a asp-action="Popular" class="btn btn-outline-primary">Popular pieces</a>
</div>

@if (Model?.Any() == true)
{
    <div class="row g-3">
        @foreach (var piece in Model)
        {
            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h2 class="h5">@piece.Title</h2>
                        <p class="mb-1"><strong>Artist:</strong> @piece.ArtistName</p>
                        <p class="mb-3"><strong>Style:</strong> @piece.Style</p>
                        <a asp-action="Details" asp-route-id="@piece.Id" class="btn btn-sm btn-primary">View details</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="alert alert-secondary">No art pieces are available yet.</div>
}
