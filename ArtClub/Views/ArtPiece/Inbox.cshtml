@model IEnumerable<ArtClub.Models.ViewModels.InvitationInboxViewModel>
@{
    ViewData["Title"] = "Invitation Inbox";
}

<h1>Invitation Inbox</h1>
<p class="text-muted">View invitation status and event communication.</p>

@if (Model?.Any() == true)
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Event</th>
                <th>Sender</th>
                <th>Status</th>
                <th>Sent</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.EventTitle</td>
                    <td>@item.SenderName</td>
                    <td>@item.Status</td>
                    <td>@item.SentAt.ToString("dd MMM yyyy")</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-secondary">No invitations are available.</div>
}