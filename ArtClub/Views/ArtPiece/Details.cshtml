@model ArtClub.Models.ViewModels.ArtPieceDetailsViewModel

@{
    ViewData["Title"] = "Art piece details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1>Art piece details</h1>
        <p class="text-muted mb-0">Detailed information about the selected art piece.</p>
    </div>

    <a asp-action="Index" class="btn btn-secondary">Back to collection</a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <h2 class="h4">@Model.Title</h2>

        <p><strong>Creator:</strong> @Model.Creator</p>
        <p><strong>Image URL:</strong> @Model.Description</p>
        <p><strong>Status:</strong> @Model.LastUpdated</p>

        @if (!string.IsNullOrWhiteSpace(Model.Description))
        {
            <div class="mt-3">
                <img src="@Model.Description" alt="@Model.Title" class="img-fluid rounded" style="max-height: 300px;" />
            </div>
        }

        <h3 class="h5 mt-4">Associated events</h3>

        @if (Model.AssociatedEvents != null && Model.AssociatedEvents.Any())
        {
            <ul>
                @foreach (var item in Model.AssociatedEvents)
                {
                    <li>@item</li>
                }
            </ul>
        }
        else
        {
            <p class="text-muted mb-0">No associated events are listed.</p>
        }

        <div class="mt-4">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Delete</a>
            <a asp-action="Index" class="btn btn-secondary">Back</a>
        </div>
    </div>
</div>